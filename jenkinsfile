pipeline {

    agent any

    options {
        timestamps()
    }

    environment {

        AWS_REGION    = "us-east-1"

        ECR_REPO      = "761018849945.dkr.ecr.us-east-1.amazonaws.com/my-app-repo"

        IMAGE_TAG     = "${BUILD_NUMBER}"

        IMAGE_NAME    = "my-app:${BUILD_NUMBER}"

        DEPLOY_TO_EKS = "true"
    }

    stages {

        // ====================================================
        // CHECKOUT SOURCE CODE
        // ====================================================

        stage('Checkout') {

            steps {

                checkout scm
            }
        }

        // ====================================================
        // DEBUG WORKSPACE
        // ====================================================

        stage('Debug Workspace') {

            steps {

                sh '''
                    echo "====================================="
                    echo "CURRENT DIRECTORY"
                    echo "====================================="
                    pwd

                    echo "====================================="
                    echo "WORKSPACE CONTENTS"
                    echo "====================================="
                    ls -R

                    echo "====================================="
                    echo "SEARCHING FOR CHART.YAML"
                    echo "====================================="
                    find . -name Chart.yaml || true
                '''
            }
        }

        // ====================================================
        // BUILD NODE APP
        // ====================================================

        stage('Build App') {

            steps {

                dir('app') {

                    sh '''
                        npm install
                    '''
                }
            }
        }

        // ====================================================
        // SONARQUBE SCAN
        // ====================================================

        stage('SonarQube Scan') {

            steps {

                dir('app') {

                    withSonarQubeEnv('sonarqube') {

                        script {

                            def scannerHome = tool 'sonar-scanner'

                            sh """
                                ${scannerHome}/bin/sonar-scanner \
                                  -Dsonar.projectKey=my-app \
                                  -Dsonar.sources=.
                            """
                        }
                    }
                }
            }
        }

        // ====================================================
        // QUALITY GATE
        // ====================================================

        stage('Quality Gate') {

            steps {

                timeout(time: 5, unit: 'MINUTES') {

                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // ====================================================
        // BUILD DOCKER IMAGE
        // ====================================================

        stage('Docker Build') {

            steps {

                dir('app') {

                    sh '''
                        docker build -t $IMAGE_NAME .
                    '''
                }
            }
        }

        // ====================================================
        // SECURITY SCAN WITH TRIVY
        // ====================================================

        stage('Security Scan (Trivy)') {

            steps {

                sh '''
                    docker run --rm \
                      -v /var/run/docker.sock:/var/run/docker.sock \
                      aquasec/trivy image \
                      --severity CRITICAL,HIGH \
                      --exit-code 0 \
                      $IMAGE_NAME
                '''
            }
        }

        // ====================================================
        // PUSH IMAGE TO ECR
        // ====================================================

        stage('Push to ECR') {

            steps {

                sh '''
                    set -e

                    aws ecr get-login-password --region $AWS_REGION \
                    | docker login \
                    --username AWS \
                    --password-stdin $ECR_REPO

                    docker tag $IMAGE_NAME $ECR_REPO:$IMAGE_TAG

                    docker tag $IMAGE_NAME $ECR_REPO:latest

                    docker push $ECR_REPO:$IMAGE_TAG

                    docker push $ECR_REPO:latest
                '''
            }
        }

        // ====================================================
        // DEPLOY TO EKS WITH HELM
        // ====================================================

        stage('Deploy to EKS (Helm)') {

            when {

                expression {

                    return env.DEPLOY_TO_EKS == 'true'
                }
            }

            steps {

                sh '''

                    echo "====================================="
                    echo "DETECTING HELM CHART LOCATION"
                    echo "====================================="

                    CHART_PATH=$(find . -name Chart.yaml | head -n 1 | xargs dirname)

                    echo "Detected Helm Chart Path: $CHART_PATH"

                    if [ -z "$CHART_PATH" ]; then
                        echo "ERROR: Helm chart not found"
                        exit 1
                    fi

                    echo "====================================="
                    echo "UPDATING KUBECONFIG"
                    echo "====================================="

                    aws eks update-kubeconfig \
                      --region $AWS_REGION \
                      --name devops-cluster

                    echo "====================================="
                    echo "DEPLOYING WITH HELM"
                    echo "====================================="

                    helm upgrade --install my-app $CHART_PATH \
                      --set image.repository=$ECR_REPO \
                      --set image.tag=$IMAGE_TAG
                '''
            }
        }

        // ====================================================
        // CLEANUP
        // ====================================================

        stage('Docker Cleanup') {

            steps {

                sh '''
                    docker image prune -af || true
                '''
            }
        }
    }

    // ========================================================
    // POST ACTIONS
    // ========================================================

    post {

        success {

            echo "✅ Build ${BUILD_NUMBER} completed successfully"
        }

        failure {

            echo "❌ Build failed — investigate logs"
        }

        always {

            echo "Skipping workspace cleanup temporarily"
        }
    }
}
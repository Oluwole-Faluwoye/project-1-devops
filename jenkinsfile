pipeline {
  agent any

  environment {
    AWS_REGION = "us-east-1"
    ECR_REPO   = "761018849945.dkr.ecr.us-east-1.amazonaws.com/my-app-repo"
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Debug Path') {
      steps {
        sh '''
          pwd
          ls -R
        '''
      }
    }

    stage('Build App') {
      steps {
        dir('app') {
          sh '''
            npm install
          '''
        }
      }
    }

    stage('SonarQube Scan') {
      steps {
        withSonarQubeEnv('sonarqube') {
          script {
            def scannerHome = tool 'sonar-scanner'
            sh """
              ${scannerHome}/bin/sonar-scanner \
                -Dsonar.projectKey=my-app \
                -Dsonar.sources=app
            """
          }
        }
      }
    }

    stage('Quality Gate') {
      steps {
        timeout(time: 2, unit: 'MINUTES') {
          waitForQualityGate abortPipeline: true
        }
      }
    }

    stage('Docker Build') {
      steps {
        sh '''
          docker build -t my-app:latest ./app
        '''
      }
    }

    stage('Trivy Scan') {
      steps {
        sh '''
          docker run --rm \
            -v /var/run/docker.sock:/var/run/docker.sock \
            -v $HOME/.cache/trivy:/root/.cache/trivy \
            aquasec/trivy image \
            --exit-code 1 \
            --severity HIGH,CRITICAL \
            my-app:latest
        '''
      }
    }

    stage('Push to ECR') {
      steps {
        sh '''
          set -e

          aws ecr get-login-password --region $AWS_REGION \
          | docker login --username AWS --password-stdin $ECR_REPO

          docker tag my-app:latest $ECR_REPO:latest
          docker push $ECR_REPO:latest
        '''
      }
    }

    stage('Deploy to EKS (Helm)') {
      steps {
        sh '''
          aws eks update-kubeconfig --region $AWS_REGION --name devops-cluster

          docker run --rm \
            -v $HOME/.kube:/root/.kube \
            -v /home/ec2-user/.aws:/root/.aws \
            -v $(pwd):/workspace \
            -w /workspace \
            alpine/helm:3.14.0 \
            upgrade --install my-app ./helm/my-app \
            --set image.repository=$ECR_REPO \
            --set image.tag=latest
        '''
      }
    }

  }

  post {
    success {
      echo "✅ Pipeline completed successfully!"
    }
    failure {
      echo "❌ Pipeline failed. Check logs."
    }
  }
}